{
  "name": "ka-cave",
  "version": "1.0.0",
  "description": "KA cave - A modern web application for creating, reading, and managing digital books",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node backend/server.js",
    "dev:client": "vite",
    "build": "vite build",
    "build:analyze": "vite build --analyze",
    "preview": "vite preview",
    "start": "node backend/server.js",
    "seed": "node backend/seed.js",
    "optimize": "npm run build && npm run build:analyze",
    "lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report"
  },
  "keywords": [
    "book",
    "writing",
    "editor",
    "reader",
    "collaborative"
  ],
  "author": "BookWriter Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.0.0",
    "lighthouse": "^11.0.0",
    "vite-bundle-analyzer": "^4.7.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0"
  }
}
